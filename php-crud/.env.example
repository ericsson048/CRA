APP_NAME="ResourceHub"
APP_ENV="local"
APP_DEBUG="true"
APP_TIMEZONE="Africa/Johannesburg"
APP_URL="http://localhost/php-crud"
APP_AUTO_MIGRATE="true"
APP_SEED_DEMO_DATA="true"

DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="resource_manager"
DB_USER="resourcehub_app"
DB_PASSWORD="change-me"

SESSION_TIMEOUT="1800"
SESSION_SECURE_COOKIE="false"
LOGIN_MAX_ATTEMPTS="5"
LOGIN_WINDOW_MINUTES="15"

EMAIL_HOST="smtp.example.com"
EMAIL_PORT="587"
EMAIL_HOST_USER="noreply@example.com"
EMAIL_HOST_PASSWORD="replace-with-app-password"
EMAIL_USE_TLS="true"
EMAIL_IMPLICIT_TLS="false"
DEFAULT_FROM_EMAIL="noreply@example.com"
